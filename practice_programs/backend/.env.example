# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore.
# ============================================================

# ── AI ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here          # https://console.groq.com

# ── GitHub integration ──────────────────────────────────────
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_personal_access_token  # Needs repo + read:user scope

# ── LeetCode ────────────────────────────────────────────────
LEETCODE_USERNAME=your_leetcode_username

# ── Database ─────────────────────────────────────────────────
# Local dev: leave as-is (SQLite file)
DATABASE_URL=sqlite:///./learning_tracker.db
# Production: use your Supabase connection string, e.g:
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Encryption (for stored OAuth tokens) ────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ── Google Calendar OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── CORS — comma-separated allowed origins ──────────────────
# Local:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production (add your Render frontend URL):
# CORS_ORIGINS=https://your-app.onrender.com,http://localhost:5173

# ── Scheduler ────────────────────────────────────────────────
QUIZ_HOUR=20
QUIZ_MINUTE=30
LOG_LEVEL=INFO

# ── Optional: Bootstrap an admin user on first startup ──────
BOOTSTRAP_USER_EMAIL=your_email@example.com
BOOTSTRAP_USER_PASSWORD=your_password_here

# ── Optional: Error tracking ─────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
ENVIRONMENT=development   # Change to "production" on Render

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.puqtexejqrzthxlnknrg:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.puqtexejqrzthxlnknrg:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"