# =============================================================================
# TEMPLATE ONLY — copy to .env and fill in REAL values there.
# NEVER put real API keys, passwords, or JWT secrets in this file.
# This file is safe to commit to Git. Your .env file is gitignored.
# =============================================================================
#   cp .env.example .env   (then edit .env)

GROQ_API_KEY=your_groq_key_here
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_token_here
LEETCODE_USERNAME=your_leetcode_username

DATABASE_URL=sqlite:///./learning_tracker.db

# PostgreSQL (optional: docker compose up -d from repo root)
# DATABASE_URL=postgresql://productivity:productivity@localhost:5432/productivity_db
# USE_ALEMBIC=true

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

QUIZ_HOUR=20
QUIZ_MINUTE=30
LOG_LEVEL=INFO

JWT_SECRET_KEY=replace-with-long-random-secret-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional — only for claiming old data on a fresh database
# BOOTSTRAP_USER_EMAIL=you@example.com
# BOOTSTRAP_USER_PASSWORD=your-secure-password

# SENTRY_DSN=
# ENVIRONMENT=development
