{
  "manifest_version": 3,
  "name": "Antigravity — AI Learning Tracker",
  "version": "2.0.0",
  "description": "Tracks educational YouTube videos and LeetCode solutions with offline-first sync.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.leetcode.com/*",
    "http://localhost:8000/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*", "http://127.0.0.1:5173/*"],
      "js": ["auth.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.leetcode.com/problems/*"],
      "js": ["leetcode_content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Antigravity Learning Tracker"
  },
  "icons": {}
}