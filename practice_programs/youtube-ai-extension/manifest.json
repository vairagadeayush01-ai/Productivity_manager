{
  "manifest_version": 3,
  "name": "YT AI Learning Tracker",
  "version": "1.0.0",
  "description": "Detects and tracks educational YouTube videos.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YT AI Learning Tracker"
  },
  "icons": {}
}